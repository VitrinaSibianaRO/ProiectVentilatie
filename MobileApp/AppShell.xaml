<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="ProiectVentilatie.Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:ProiectVentilatie.Mobile.Views"
    Shell.FlyoutBehavior="Disabled"
    Shell.TabBarIsVisible="False"
    Shell.NavBarIsVisible="False"
    Shell.PresentationMode="NotAnimated"
    Title="Ventilatie Smart"
    BackgroundColor="{StaticResource BackgroundColor}">

    <TabBar>
        <ShellContent x:Name="DashboardTab" Route="DashboardPage" />
        <ShellContent x:Name="CamerasTab"   Route="CamerasPage" />
        <ShellContent x:Name="SettingsTab"  Route="SettingsPage" />
        <ShellContent x:Name="SystemTab"    Route="SystemPage" />
        <ShellContent x:Name="TvTab"        Route="TvPage" />
    </TabBar>

    <!-- Route-urile modale CameraFullscreenPage si CameraSettingsPage
         sunt inregistrate in AppShell.xaml.cs via Routing.RegisterRoute -->

</Shell>
