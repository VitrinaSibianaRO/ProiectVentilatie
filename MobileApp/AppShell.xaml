<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="ProiectVentilatie.Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:ProiectVentilatie.Mobile.Views"
    Shell.FlyoutBehavior="Disabled"
    Shell.TabBarIsVisible="False"
    Shell.NavBarIsVisible="False"
    Shell.PresentationMode="NotAnimated"
    Title="Ventilatie Smart"
    BackgroundColor="{StaticResource BackgroundColor}">

    <TabBar>
        <ShellContent Route="DashboardPage" ContentTemplate="{DataTemplate views:DashboardPage}" />
        <ShellContent Route="DevicesPage" ContentTemplate="{DataTemplate views:DevicesPage}" />
        <ShellContent Route="SettingsPage" ContentTemplate="{DataTemplate views:SettingsPage}" />
        <ShellContent Route="ReportsPage" ContentTemplate="{DataTemplate views:LogPage}" />
        <ShellContent Route="SystemPage" ContentTemplate="{DataTemplate views:SystemPage}" />
    </TabBar>

</Shell>
