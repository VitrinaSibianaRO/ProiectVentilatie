<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="ProiectVentilatie.Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:ProiectVentilatie.Mobile.Views"
    Shell.FlyoutBehavior="Disabled"
    Title="Ventilatie Smart"
    BackgroundColor="{StaticResource BackgroundColor}"
    TabBarBackgroundColor="{StaticResource SurfaceColor}"
    TabBarTitleColor="{StaticResource PrimaryColor}"
    TabBarUnselectedColor="{StaticResource SecondaryTextColor}">

    <TabBar>
        <Tab Title="Dashboard" Icon="dashboard.png">
            <ShellContent ContentTemplate="{DataTemplate local:DashboardPage}" />
        </Tab>
        <Tab Title="Setari" Icon="settings.png">
            <ShellContent ContentTemplate="{DataTemplate local:SettingsPage}" />
        </Tab>
        <Tab Title="Sistem" Icon="system.png">
            <ShellContent ContentTemplate="{DataTemplate local:SystemPage}" />
        </Tab>
    </TabBar>

</Shell>
