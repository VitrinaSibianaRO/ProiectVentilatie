<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProiectVentilatie.Mobile.Views.SettingsPage"
             Title="Setari">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            <Label Text="Setari Automatizare" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource PrimaryColor}"/>
            
            <Label Text="Poti seta aici pragurile. Partea de ViewModel va fi implementata asemanator cu Dashboard." />
            
            <Frame>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Prag Temperatura (°C)" />
                    <Slider Minimum="20" Maximum="60" Value="45" />
                    
                    <Label Text="Prag Umiditate (%)" />
                    <Slider Minimum="30" Maximum="100" Value="60" />
                </VerticalStackLayout>
            </Frame>

            <Button Text="SALVEAZA SETARI" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
