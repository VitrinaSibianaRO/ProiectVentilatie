<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ProiectVentilatie.Mobile.ViewModels"
             xmlns:controls="clr-namespace:ProiectVentilatie.Mobile.Controls"
             x:Class="ProiectVentilatie.Mobile.Views.DashboardPage"
             Title="Dashboard">

    <ScrollView>
        <VerticalStackLayout Padding="15" Spacing="20">
            
            <Label Text="{Binding ConnectionStatus}" 
                   HorizontalOptions="Center" 
                   TextColor="{StaticResource PrimaryColor}" 
                   FontAttributes="Bold" />

            <Button Text="REFRESH DATE" Command="{Binding RefreshCommand}" Margin="10,0"/>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="15" RowSpacing="20">
                <!-- Stanga -->
                <VerticalStackLayout Grid.Column="0" Spacing="20">
                    <controls:GaugeView Value="{Binding LeftTemp}" MinValue="-10" MaxValue="40" Units="°C" Title="TEMP STÂNGA" ProgressColor="{StaticResource PrimaryColor}" HeightRequest="160"/>
                    <controls:GaugeView Value="{Binding LeftHum}" MinValue="0" MaxValue="100" Units="%" Title="UMID STÂNGA" ProgressColor="{StaticResource PrimaryColor}" HeightRequest="160"/>
                    
                    <Frame Padding="10" BackgroundColor="{StaticResource SurfaceColor}">
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Vent. Stânga" FontSize="14" HorizontalOptions="Center" TextColor="LightGray"/>
                            <Label Text="{Binding LeftRelay}" FontSize="16" FontAttributes="Bold" HorizontalOptions="Center" TextColor="{StaticResource PrimaryColor}"/>
                            <Button Text="TOGGLE" Command="{Binding ToggleLeftCommand}" HeightRequest="35" FontSize="12"/>
                        </VerticalStackLayout>
                    </Frame>
                </VerticalStackLayout>

                <!-- Dreapta -->
                <VerticalStackLayout Grid.Column="1" Spacing="20">
                    <controls:GaugeView Value="{Binding RightTemp}" MinValue="-10" MaxValue="40" Units="°C" Title="TEMP DREAPTA" ProgressColor="{StaticResource PrimaryColor}" HeightRequest="160"/>
                    <controls:GaugeView Value="{Binding RightHum}" MinValue="0" MaxValue="100" Units="%" Title="UMID DREAPTA" ProgressColor="{StaticResource PrimaryColor}" HeightRequest="160"/>
                    
                    <Frame Padding="10" BackgroundColor="{StaticResource SurfaceColor}">
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Vent. Dreapta" FontSize="14" HorizontalOptions="Center" TextColor="LightGray"/>
                            <Label Text="{Binding RightRelay}" FontSize="16" FontAttributes="Bold" HorizontalOptions="Center" TextColor="{StaticResource PrimaryColor}"/>
                            <Button Text="TOGGLE" Command="{Binding ToggleRightCommand}" HeightRequest="35" FontSize="12"/>
                        </VerticalStackLayout>
                    </Frame>
                </VerticalStackLayout>
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
