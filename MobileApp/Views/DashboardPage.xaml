<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ProiectVentilatie.Mobile.ViewModels"
             xmlns:controls="clr-namespace:ProiectVentilatie.Mobile.Controls"
             x:Class="ProiectVentilatie.Mobile.Views.DashboardPage"
             x:DataType="vm:DashboardViewModel"
             Title="Dashboard">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- ═══ VITRINA HERO ═══ -->
            <Grid HeightRequest="190" BackgroundColor="#000d1f">

                <!-- HexGrid background layer -->
                <controls:HexGridView />

                <!-- ScanLine CRT effect -->
                <controls:ScanLineView />

                <!-- Top-right: Refresh button -->
                <Button Text="↻" Grid.Row="0"
                        HorizontalOptions="End" VerticalOptions="Start"
                        Margin="0,10,15,0"
                        WidthRequest="40" HeightRequest="40"
                        CornerRadius="20" FontSize="18"
                        Command="{Binding RefreshCommand}" />

                <!-- Bottom content overlay -->
                <VerticalStackLayout VerticalOptions="End" Padding="20,0,20,15" Spacing="4">
                    <Label Text="MAIN VENTILATION SYSTEM"
                           FontFamily="RajdhaniBold" FontSize="13"
                           TextColor="{StaticResource SecondaryTextColor}" />
                    <HorizontalStackLayout Spacing="12">
                        <controls:PulseBadgeView BadgeColor="{Binding OnlineBadgeColor}"
                                                  WidthRequest="12" HeightRequest="12"
                                                  VerticalOptions="Center" />
                        <Label Text="{Binding OnlineText}"
                               FontFamily="RajdhaniBold" FontSize="20"
                               TextColor="{Binding OnlineBadgeColor}" />
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="20">
                        <Label Text="{Binding UptimeText, StringFormat='UP {0}'}"
                               FontFamily="ShareTechMono" FontSize="11"
                               TextColor="{StaticResource SecondaryTextColor}" />
                        <Label Text="{Binding LastUpdateText}"
                               FontFamily="ShareTechMono" FontSize="11"
                               TextColor="{StaticResource SecondaryTextColor}" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Grid>

            <VerticalStackLayout Padding="15" Spacing="14">

                <!-- ═══ LOCK BANNER ═══ -->
                <Border Stroke="#ffaa00" StrokeThickness="1"
                        Padding="12,10" BackgroundColor="#1a1200"
                        IsVisible="{Binding LockBannerVisible}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                        <Label Text="🔒" FontSize="16" VerticalOptions="Center" />
                        <Label Text="{Binding LockBannerText}"
                               FontFamily="RajdhaniBold" FontSize="13"
                               TextColor="#ffaa00" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>

                <!-- ═══ ZONE CARDS ═══ -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">

                    <!-- ── ZONA STÂNGA ── -->
                    <Border Grid.Column="0"
                            Stroke="{StaticResource PrimaryColor}" StrokeThickness="0.8"
                            BackgroundColor="#060f1e" Padding="12">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="14">

                            <!-- Card header -->
                            <VerticalStackLayout Spacing="1" HorizontalOptions="Center">
                                <Label Text="ZONA STÂNGA"
                                       FontFamily="RajdhaniBold" FontSize="12"
                                       TextColor="{StaticResource PrimaryColor}"
                                       HorizontalOptions="Center" />
                                <BoxView HeightRequest="1" Color="{StaticResource PrimaryColor}" Opacity="0.3" />
                            </VerticalStackLayout>

                            <!-- Temperature -->
                            <Grid ColumnDefinitions="Auto, *" ColumnSpacing="10">
                                <controls:ThermometerView Temperature="{Binding LeftTemp}"
                                                           WidthRequest="28" HeightRequest="110" />
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="0">
                                    <Label Text="{Binding LeftTemp, StringFormat='{0:F1}'}"
                                           FontFamily="ShareTechMono" FontSize="30"
                                           TextColor="White" />
                                    <Label Text="°CELSIUS"
                                           FontFamily="Rajdhani" FontSize="10"
                                           TextColor="{StaticResource SecondaryTextColor}" />
                                </VerticalStackLayout>
                            </Grid>

                            <!-- Humidity -->
                            <Grid ColumnDefinitions="Auto, *" ColumnSpacing="10">
                                <controls:DropletView Humidity="{Binding LeftHum}"
                                                       WidthRequest="28" HeightRequest="42" />
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                    <Label Text="{Binding LeftHum, StringFormat='{0:F0}%'}"
                                           FontFamily="ShareTechMono" FontSize="22"
                                           TextColor="{StaticResource PrimaryColor}" />
                                    <Label Text="UMIDITATE"
                                           FontFamily="Rajdhani" FontSize="10"
                                           TextColor="{StaticResource SecondaryTextColor}" />
                                </VerticalStackLayout>
                            </Grid>

                            <BoxView HeightRequest="1" Color="{StaticResource PrimaryColor}" Opacity="0.15" />

                            <!-- Fan + Status -->
                            <Grid ColumnDefinitions="Auto, *" ColumnSpacing="10">
                                <controls:MiniFanView IsOn="{Binding LeftRelayActive}"
                                                       WidthRequest="44" HeightRequest="44" />
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                                    <Label Text="{Binding RelayLeftText}"
                                           FontFamily="RajdhaniBold" FontSize="15"
                                           TextColor="{StaticResource SecondaryColor}" />
                                    <Label Text="{Binding OverrideLeftText}"
                                           FontFamily="Rajdhani" FontSize="10"
                                           TextColor="{StaticResource SecondaryTextColor}" />
                                </VerticalStackLayout>
                            </Grid>

                            <!-- Override button -->
                            <Button Text="OVERRIDE"
                                    Command="{Binding ToggleLeftCommand}"
                                    IsEnabled="{Binding IsControlEnabled}"
                                    FontSize="12" HeightRequest="36" CornerRadius="8" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- ── ZONA DREAPTA ── -->
                    <Border Grid.Column="1"
                            Stroke="{StaticResource SecondaryColor}" StrokeThickness="0.8"
                            BackgroundColor="#060f1e" Padding="12">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="14">

                            <!-- Card header -->
                            <VerticalStackLayout Spacing="1" HorizontalOptions="Center">
                                <Label Text="ZONA DREAPTA"
                                       FontFamily="RajdhaniBold" FontSize="12"
                                       TextColor="{StaticResource SecondaryColor}"
                                       HorizontalOptions="Center" />
                                <BoxView HeightRequest="1" Color="{StaticResource SecondaryColor}" Opacity="0.3" />
                            </VerticalStackLayout>

                            <!-- Temperature -->
                            <Grid ColumnDefinitions="Auto, *" ColumnSpacing="10">
                                <controls:ThermometerView Temperature="{Binding RightTemp}"
                                                           WidthRequest="28" HeightRequest="110" />
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="0">
                                    <Label Text="{Binding RightTemp, StringFormat='{0:F1}'}"
                                           FontFamily="ShareTechMono" FontSize="30"
                                           TextColor="White" />
                                    <Label Text="°CELSIUS"
                                           FontFamily="Rajdhani" FontSize="10"
                                           TextColor="{StaticResource SecondaryTextColor}" />
                                </VerticalStackLayout>
                            </Grid>

                            <!-- Humidity -->
                            <Grid ColumnDefinitions="Auto, *" ColumnSpacing="10">
                                <controls:DropletView Humidity="{Binding RightHum}"
                                                       WidthRequest="28" HeightRequest="42" />
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                    <Label Text="{Binding RightHum, StringFormat='{0:F0}%'}"
                                           FontFamily="ShareTechMono" FontSize="22"
                                           TextColor="{StaticResource SecondaryColor}" />
                                    <Label Text="UMIDITATE"
                                           FontFamily="Rajdhani" FontSize="10"
                                           TextColor="{StaticResource SecondaryTextColor}" />
                                </VerticalStackLayout>
                            </Grid>

                            <BoxView HeightRequest="1" Color="{StaticResource SecondaryColor}" Opacity="0.15" />

                            <!-- Fan + Status -->
                            <Grid ColumnDefinitions="Auto, *" ColumnSpacing="10">
                                <controls:MiniFanView IsOn="{Binding RightRelayActive}"
                                                       WidthRequest="44" HeightRequest="44" />
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                                    <Label Text="{Binding RelayRightText}"
                                           FontFamily="RajdhaniBold" FontSize="15"
                                           TextColor="{StaticResource SecondaryColor}" />
                                    <Label Text="{Binding OverrideRightText}"
                                           FontFamily="Rajdhani" FontSize="10"
                                           TextColor="{StaticResource SecondaryTextColor}" />
                                </VerticalStackLayout>
                            </Grid>

                            <!-- Override button -->
                            <Button Text="OVERRIDE"
                                    Command="{Binding ToggleRightCommand}"
                                    IsEnabled="{Binding IsControlEnabled}"
                                    BorderColor="{StaticResource SecondaryColor}"
                                    TextColor="{StaticResource SecondaryColor}"
                                    FontSize="12" HeightRequest="36" CornerRadius="8" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
