<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:ProiectVentilatie.Mobile.Controls"
             xmlns:vm="clr-namespace:ProiectVentilatie.Mobile.ViewModels"
             xmlns:converters="clr-namespace:ProiectVentilatie.Mobile.Converters"
             x:Class="ProiectVentilatie.Mobile.Views.DashboardPage"
             x:DataType="vm:DashboardViewModel">

    <ContentPage.Resources>
        <converters:BoolToColorConverter x:Key="BoolToColorConverter" />
    </ContentPage.Resources>

    <Grid RowDefinitions="*,Auto" BackgroundColor="{StaticResource BackgroundColor}">
        <!-- Scanline Effect (Full Page) -->
        <controls:ScanLineView Grid.Row="0" InputTransparent="True" ZIndex="100" />

        <ScrollView Grid.Row="0" Padding="0,0,0,12">
            <VerticalStackLayout Spacing="0">

                <!-- HERO SECTION — VitrinaHero animated showcase -->
                <controls:VitrinaHeroView
                    HeightRequest="214"
                    LeftTemp="{Binding LeftTemp}"
                    LeftHum="{Binding LeftHum}"
                    LeftRelay="{Binding LeftRelay}"
                    LeftOverride="{Binding LeftOverride}"
                    RightTemp="{Binding RightTemp}"
                    RightHum="{Binding RightHum}"
                    RightRelay="{Binding RightRelay}"
                    RightOverride="{Binding RightOverride}"
                    FwBuild="{Binding FwBuild}"
                    UptimeSec="{Binding UptimeSec}"
                    HeapBytes="{Binding HeapBytes}"
                    IsOnline="{Binding IsOnline}" />

                <!-- LOCK BANNER -->
                <Border IsVisible="{Binding LockBannerVisible}"
                        Margin="14,8,14,0"
                        Padding="12,8"
                        BackgroundColor="#1Fff7a45"
                        Stroke="#55ff7a45"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 10">
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="⚠" TextColor="{StaticResource PrimaryOrange}" FontSize="14" VerticalOptions="Center" />
                        <Label Text="{Binding LockBannerText}"
                               TextColor="{StaticResource PrimaryOrange}"
                               FontSize="13" VerticalOptions="Center"
                               Style="{StaticResource LabelRajdhani}" />
                    </HorizontalStackLayout>
                </Border>

                <!-- REBOOT WARNING BANNER -->
                <Border IsVisible="{Binding RebootWarningVisible}"
                        Margin="14,6,14,0" Padding="12,8"
                        BackgroundColor="#1Fffb347"
                        Stroke="#55ffb347" StrokeThickness="1"
                        StrokeShape="RoundRectangle 10">
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="⚠" TextColor="#FFB347" FontSize="13" VerticalOptions="Center"/>
                        <Label Text="{Binding RebootWarningText}"
                               TextColor="#FFB347" FontSize="12" VerticalOptions="Center"
                               Style="{StaticResource LabelRajdhani}" />
                    </HorizontalStackLayout>
                </Border>

                <!-- SYSTEM STATUS CARD -->
                <Border Style="{StaticResource IndustrialCard}" Margin="14,10,14,0">
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="SYSTEM STATUS" FontSize="9" CharacterSpacing="2" Opacity="0.4"
                                   Style="{StaticResource LabelRajdhani}" />
                            <HorizontalStackLayout Spacing="8">
                                <controls:PulseBadgeView IsOnline="{Binding IsOnline}"
                                                          HeightRequest="10" WidthRequest="10"
                                                          VerticalOptions="Center" />
                                <Label Text="{Binding OnlineText}"
                                       TextColor="{Binding IsOnline, Converter={StaticResource BoolToColorConverter}}"
                                       FontSize="15" FontAttributes="Bold" CharacterSpacing="1.5"
                                       Style="{StaticResource LabelRajdhani}" />
                            </HorizontalStackLayout>
                            <Label Text="{Binding LastUpdateText}"
                                   FontSize="10" Opacity="0.45"
                                   Style="{StaticResource LabelShareTech}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" HorizontalOptions="End" Spacing="4">
                            <Label Text="UPTIME" FontSize="9" CharacterSpacing="1.5" Opacity="0.4"
                                   HorizontalOptions="End" Style="{StaticResource LabelRajdhani}" />
                            <Label Text="{Binding UptimeText}"
                                   FontSize="14" FontAttributes="Bold" HorizontalOptions="End"
                                   Style="{StaticResource LabelShareTech}" />
                            <Label Text="LED" FontSize="9" CharacterSpacing="1.5" Opacity="0.4"
                                   HorizontalOptions="End" Style="{StaticResource LabelRajdhani}" />
                            <Label Text="{Binding LedIntensityText}"
                                   FontSize="14" FontAttributes="Bold" HorizontalOptions="End"
                                   TextColor="{StaticResource PrimaryOrange}"
                                   Style="{StaticResource LabelShareTech}" />
                            <Button Text="↻ REFRESH"
                                    Style="{StaticResource CyberButton}"
                                    HeightRequest="30" Padding="10,0" FontSize="11"
                                    Command="{Binding RefreshCommand}" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- ZONE CARDS -->
                <Grid ColumnDefinitions="*,*" Margin="14,10,14,0" ColumnSpacing="10">

                    <!-- LEFT ZONE -->
                    <Border Grid.Column="0" Style="{StaticResource IndustrialCard}" Padding="12,12">
                        <VerticalStackLayout Spacing="10">
                            <!-- Zone header -->
                            <HorizontalStackLayout Spacing="6">
                                <BoxView WidthRequest="3" HeightRequest="14" Color="{StaticResource PrimaryCyan}" CornerRadius="2" />
                                <Label Text="ZONA STÂNGA" FontSize="12" FontAttributes="Bold"
                                       CharacterSpacing="0.5" Style="{StaticResource LabelRajdhani}" />
                            </HorizontalStackLayout>

                            <!-- Temperature row -->
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                <controls:ThermometerView Grid.Column="0"
                                    Temperature="{Binding LeftTemp}"
                                    WidthRequest="20" HeightRequest="56" />
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                    <Label Text="TEMP" FontSize="8" Opacity="0.4"
                                           Style="{StaticResource LabelRajdhani}" />
                                    <Label Text="{Binding LeftTemp, StringFormat='{0:0.0}°C'}"
                                           FontSize="18" FontAttributes="Bold"
                                           TextColor="{StaticResource PrimaryOrange}"
                                           Style="{StaticResource LabelShareTech}" />
                                </VerticalStackLayout>
                            </Grid>

                            <!-- Humidity row -->
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                <controls:DropletView Grid.Column="0"
                                    Humidity="{Binding LeftHum}"
                                    WidthRequest="22" HeightRequest="30" />
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                    <Label Text="HUM" FontSize="8" Opacity="0.4"
                                           Style="{StaticResource LabelRajdhani}" />
                                    <Label Text="{Binding LeftHum, StringFormat='{0:0.0}%'}"
                                           FontSize="18" FontAttributes="Bold"
                                           TextColor="{StaticResource PrimaryCyan}"
                                           Style="{StaticResource LabelShareTech}" />
                                </VerticalStackLayout>
                            </Grid>

                            <!-- Fan + relay row -->
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                <controls:MiniFanView Grid.Column="0"
                                    IsOn="{Binding LeftRelayActive}"
                                    WidthRequest="32" HeightRequest="32" />
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                    <Label Text="VENTILATOR" FontSize="8" Opacity="0.4"
                                           Style="{StaticResource LabelRajdhani}" />
                                    <Label Text="{Binding RelayLeftText}"
                                           FontSize="13" FontAttributes="Bold"
                                           TextColor="{Binding LeftRelay, Converter={StaticResource BoolToColorConverter}}"
                                           Style="{StaticResource LabelRajdhani}" />
                                </VerticalStackLayout>
                            </Grid>

                            <!-- Override button -->
                            <Button Text="{Binding OverrideLeftText}"
                                    Style="{StaticResource CyberButtonOrange}"
                                    HeightRequest="32" FontSize="11"
                                    IsEnabled="{Binding IsControlEnabled}"
                                    Command="{Binding ToggleLeftCommand}" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- RIGHT ZONE -->
                    <Border Grid.Column="1" Style="{StaticResource IndustrialCard}" Padding="12,12">
                        <VerticalStackLayout Spacing="10">
                            <!-- Zone header -->
                            <HorizontalStackLayout Spacing="6">
                                <BoxView WidthRequest="3" HeightRequest="14" Color="{StaticResource PrimaryGreen}" CornerRadius="2" />
                                <Label Text="ZONA DREAPTA" FontSize="12" FontAttributes="Bold"
                                       CharacterSpacing="0.5" Style="{StaticResource LabelRajdhani}" />
                            </HorizontalStackLayout>

                            <!-- Temperature row -->
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                <controls:ThermometerView Grid.Column="0"
                                    Temperature="{Binding RightTemp}"
                                    WidthRequest="20" HeightRequest="56" />
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                    <Label Text="TEMP" FontSize="8" Opacity="0.4"
                                           Style="{StaticResource LabelRajdhani}" />
                                    <Label Text="{Binding RightTemp, StringFormat='{0:0.0}°C'}"
                                           FontSize="18" FontAttributes="Bold"
                                           TextColor="{StaticResource PrimaryOrange}"
                                           Style="{StaticResource LabelShareTech}" />
                                </VerticalStackLayout>
                            </Grid>

                            <!-- Humidity row -->
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                <controls:DropletView Grid.Column="0"
                                    Humidity="{Binding RightHum}"
                                    WidthRequest="22" HeightRequest="30" />
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                    <Label Text="HUM" FontSize="8" Opacity="0.4"
                                           Style="{StaticResource LabelRajdhani}" />
                                    <Label Text="{Binding RightHum, StringFormat='{0:0.0}%'}"
                                           FontSize="18" FontAttributes="Bold"
                                           TextColor="{StaticResource PrimaryCyan}"
                                           Style="{StaticResource LabelShareTech}" />
                                </VerticalStackLayout>
                            </Grid>

                            <!-- Fan + relay row -->
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                <controls:MiniFanView Grid.Column="0"
                                    IsOn="{Binding RightRelayActive}"
                                    WidthRequest="32" HeightRequest="32" />
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                    <Label Text="VENTILATOR" FontSize="8" Opacity="0.4"
                                           Style="{StaticResource LabelRajdhani}" />
                                    <Label Text="{Binding RelayRightText}"
                                           FontSize="13" FontAttributes="Bold"
                                           TextColor="{Binding RightRelay, Converter={StaticResource BoolToColorConverter}}"
                                           Style="{StaticResource LabelRajdhani}">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding RightFailsafe}" Value="True">
                                                <Setter Property="TextColor" Value="Red" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                </VerticalStackLayout>
                            </Grid>

                            <!-- Override button -->
                            <Button Text="{Binding OverrideRightText}"
                                    Style="{StaticResource CyberButtonOrange}"
                                    HeightRequest="32" FontSize="11"
                                    IsEnabled="{Binding IsControlEnabled}"
                                    Command="{Binding ToggleRightCommand}" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- TV TELEMETRIE — o singura linie, fit la latime -->
                <Border IsVisible="{Binding TvDataVisible}"
                        Margin="14,6,14,0" Padding="12,10"
                        BackgroundColor="#0DFFFFFF"
                        Stroke="#18FFFFFF"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 8">
                    <Grid ColumnDefinitions="Auto,*,*,*,*" ColumnSpacing="0">
                        <!-- Eticheta TV -->
                        <Label Grid.Column="0" Text="TV  " FontSize="11" Opacity="0.35"
                               VerticalOptions="Center"
                               Style="{StaticResource LabelRajdhani}" />
                        <!-- Temperatura -->
                        <Label Grid.Column="1"
                               Text="{Binding TvTempText}"
                               FontSize="16" FontAttributes="Bold"
                               TextColor="{StaticResource PrimaryOrange}"
                               HorizontalOptions="Center" VerticalOptions="Center"
                               Style="{StaticResource LabelShareTech}" />
                        <!-- Ore utilizare -->
                        <Label Grid.Column="2"
                               Text="{Binding TvUsageText}"
                               FontSize="16" FontAttributes="Bold"
                               TextColor="{StaticResource PrimaryCyan}"
                               HorizontalOptions="Center" VerticalOptions="Center"
                               Style="{StaticResource LabelShareTech}" />
                        <!-- Accesibil -->
                        <Label Grid.Column="3"
                               Text="{Binding TvReachableText}"
                               FontSize="13" FontAttributes="Bold"
                               TextColor="{Binding TvReachableColor}"
                               HorizontalOptions="Center" VerticalOptions="Center"
                               Style="{StaticResource LabelRajdhani}" />
                        <!-- Power -->
                        <Label Grid.Column="4"
                               Text="{Binding TvPowerText}"
                               FontSize="13" FontAttributes="Bold"
                               TextColor="{Binding TvPowerColor}"
                               HorizontalOptions="Center" VerticalOptions="Center"
                               Style="{StaticResource LabelRajdhani}" />
                    </Grid>
                </Border>

                <!-- Spacer -->
                <BoxView HeightRequest="8" />

            </VerticalStackLayout>
        </ScrollView>

        <!-- FLOATING NAV BAR -->
        <controls:FloatingNavBar Grid.Row="1" CurrentPage="Dashboard" />
    </Grid>
</ContentPage>
