<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ProiectVentilatie.Mobile.ViewModels"
             xmlns:controls="clr-namespace:ProiectVentilatie.Mobile.Controls"
             x:Class="ProiectVentilatie.Mobile.Views.DashboardPage"
             Title="Dashboard">

    <ScrollView>
        <VerticalStackLayout Padding="15" Spacing="15">

            <!-- ═══ ONLINE BADGE ═══ -->
            <Frame Padding="8" CornerRadius="16" HorizontalOptions="Center"
                   BackgroundColor="{Binding OnlineBadgeColor}">
                <Label Text="{Binding OnlineText}"
                       FontSize="13" FontAttributes="Bold"
                       TextColor="White" HorizontalOptions="Center" />
            </Frame>

            <!-- ═══ CONNECTION STATUS ═══ -->
            <Label Text="{Binding ConnectionStatus}"
                   HorizontalOptions="Center"
                   TextColor="{StaticResource SecondaryTextColor}"
                   FontSize="12" />

            <!-- ═══ LOCK BANNER ═══ -->
            <Frame Padding="10" CornerRadius="8"
                   BackgroundColor="#4D1565C0"
                   BorderColor="#1565C0"
                   IsVisible="{Binding LockBannerVisible}">
                <Label Text="{Binding LockBannerText}"
                       FontSize="14" FontAttributes="Bold"
                       TextColor="#90CAF9" HorizontalOptions="Center" />
            </Frame>

            <!-- ═══ AGO + REFRESH ═══ -->
            <VerticalStackLayout Spacing="5">
                <Label Text="{Binding LastUpdateText}"
                       FontSize="12"
                       TextColor="{StaticResource SecondaryTextColor}"
                       HorizontalOptions="Center" />
                <Button Text="REFRESH DATE"
                        Command="{Binding RefreshCommand}"
                        Margin="20,0"
                        HeightRequest="40" FontSize="13" />
            </VerticalStackLayout>

            <!-- ═══ GAUGES: 2 COLOANE ═══ -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="15" RowSpacing="15">

                <!-- Stânga -->
                <VerticalStackLayout Grid.Column="0" Spacing="12">
                    <controls:GaugeView Value="{Binding LeftTemp}"
                                        MinValue="-10" MaxValue="50"
                                        Units="°C" Title="TEMP STÂNGA"
                                        ProgressColor="{StaticResource PrimaryColor}"
                                        HeightRequest="170" />
                    <controls:GaugeView Value="{Binding LeftHum}"
                                        MinValue="0" MaxValue="100"
                                        Units="%" Title="UMID STÂNGA"
                                        ProgressColor="{StaticResource PrimaryColor}"
                                        HeightRequest="170" />

                    <Frame Padding="10" BackgroundColor="{StaticResource SurfaceColor}"
                           BorderColor="#333333">
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Vent. Stânga"
                                   FontSize="13" HorizontalOptions="Center"
                                   TextColor="{StaticResource SecondaryTextColor}" />
                            <Label Text="{Binding RelayLeftText}"
                                   FontSize="20" FontAttributes="Bold"
                                   HorizontalOptions="Center"
                                   TextColor="{StaticResource PrimaryColor}" />
                            <Label Text="{Binding OverrideLeftText}"
                                   FontSize="12" HorizontalOptions="Center"
                                   TextColor="{StaticResource SecondaryTextColor}" />
                            <Button Text="TOGGLE OVERRIDE"
                                    Command="{Binding ToggleLeftCommand}"
                                    IsEnabled="{Binding IsControlEnabled}"
                                    HeightRequest="38" FontSize="12"
                                    CornerRadius="10" />
                        </VerticalStackLayout>
                    </Frame>
                </VerticalStackLayout>

                <!-- Dreapta -->
                <VerticalStackLayout Grid.Column="1" Spacing="12">
                    <controls:GaugeView Value="{Binding RightTemp}"
                                        MinValue="-10" MaxValue="50"
                                        Units="°C" Title="TEMP DREAPTA"
                                        ProgressColor="{StaticResource PrimaryColor}"
                                        HeightRequest="170" />
                    <controls:GaugeView Value="{Binding RightHum}"
                                        MinValue="0" MaxValue="100"
                                        Units="%" Title="UMID DREAPTA"
                                        ProgressColor="{StaticResource PrimaryColor}"
                                        HeightRequest="170" />

                    <Frame Padding="10" BackgroundColor="{StaticResource SurfaceColor}"
                           BorderColor="#333333">
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Vent. Dreapta"
                                   FontSize="13" HorizontalOptions="Center"
                                   TextColor="{StaticResource SecondaryTextColor}" />
                            <Label Text="{Binding RelayRightText}"
                                   FontSize="20" FontAttributes="Bold"
                                   HorizontalOptions="Center"
                                   TextColor="{StaticResource PrimaryColor}" />
                            <Label Text="{Binding OverrideRightText}"
                                   FontSize="12" HorizontalOptions="Center"
                                   TextColor="{StaticResource SecondaryTextColor}" />
                            <Button Text="TOGGLE OVERRIDE"
                                    Command="{Binding ToggleRightCommand}"
                                    IsEnabled="{Binding IsControlEnabled}"
                                    HeightRequest="38" FontSize="12"
                                    CornerRadius="10" />
                        </VerticalStackLayout>
                    </Frame>
                </VerticalStackLayout>

            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
