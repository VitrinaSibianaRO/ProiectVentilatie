<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ProiectVentilatie.Mobile.ViewModels"
             x:Class="ProiectVentilatie.Mobile.Views.SystemPage"
             x:DataType="vm:SystemViewModel"
             Title="Sistem">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="25">

            <VerticalStackLayout Spacing="5">
                <Label Text="SYSTEM // DIAGNOSTICS"
                       FontFamily="RajdhaniBold" FontSize="22"
                       TextColor="{StaticResource PrimaryColor}" />
                <Label Text="MONITORIZARE ȘI UPDATE FIRMWARE"
                       FontFamily="Rajdhani" FontSize="11"
                       TextColor="{StaticResource SecondaryTextColor}" />
            </VerticalStackLayout>

            <!-- ═══ SYSTEM INFO ═══ -->
            <Border Stroke="{StaticResource PrimaryColor}" StrokeThickness="0.5"
                    Padding="20" BackgroundColor="#060f1e">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="20">

                    <HorizontalStackLayout Spacing="10">
                        <BoxView WidthRequest="3" HeightRequest="18" Color="{StaticResource PrimaryColor}" VerticalOptions="Center" />
                        <Label Text="INFORMAȚII DISPOZITIV" FontFamily="RajdhaniBold" FontSize="15" TextColor="White" />
                    </HorizontalStackLayout>

                    <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="14">

                        <Label Text="STATUS ESP32" FontFamily="Rajdhani" FontSize="12" TextColor="{StaticResource SecondaryTextColor}" />
                        <Label Grid.Column="1" Text="{Binding EspStatusText}"
                               FontFamily="RajdhaniBold" FontSize="16" TextColor="{Binding EspStatusColor}" />

                        <Label Grid.Row="1" Text="FIRMWARE VERSION" FontFamily="Rajdhani" FontSize="12" TextColor="{StaticResource SecondaryTextColor}" />
                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding EspFwBuild, StringFormat='Build #{0}'}"
                               FontFamily="ShareTechMono" FontSize="16" TextColor="{StaticResource PrimaryColor}" />

                        <Label Grid.Row="2" Text="UPTIME" FontFamily="Rajdhani" FontSize="12" TextColor="{StaticResource SecondaryTextColor}" />
                        <Label Grid.Row="2" Grid.Column="1" Text="{Binding EspUptimeText}"
                               FontFamily="ShareTechMono" FontSize="16" TextColor="White" />

                        <Label Grid.Row="3" Text="BROKER" FontFamily="Rajdhani" FontSize="12" TextColor="{StaticResource SecondaryTextColor}" />
                        <Label Grid.Row="3" Grid.Column="1" Text="{Binding BrokerHost}"
                               FontFamily="ShareTechMono" FontSize="13" TextColor="{StaticResource SecondaryColor}" />
                    </Grid>

                    <BoxView HeightRequest="1" Color="{StaticResource PrimaryColor}" Opacity="0.12" />

                    <!-- Heap Memory Bar — legat dinamic -->
                    <VerticalStackLayout Spacing="8">
                        <Grid ColumnDefinitions="*, Auto">
                            <Label Text="HEAP MEMORY FREE" FontFamily="Rajdhani" FontSize="11" TextColor="{StaticResource SecondaryTextColor}" />
                            <Label Grid.Column="1" Text="{Binding EspHeapText}"
                                   FontFamily="ShareTechMono" FontSize="11" TextColor="{StaticResource SecondaryColor}" />
                        </Grid>
                        <ProgressBar Progress="{Binding EspHeapProgress}"
                                     ProgressColor="{StaticResource SecondaryColor}"
                                     HeightRequest="6" />
                        <!-- Avertisment heap critic < 30KB -->
                        <Label Text="⚠ HEAP CRITIC — REBOOT RECOMANDAT"
                               FontFamily="RajdhaniBold" FontSize="11"
                               TextColor="{StaticResource ErrorColor}"
                               IsVisible="{Binding IsHeapCritical}" />
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Border>

            <!-- ═══ OTA UPDATE ═══ -->
            <Border Stroke="{StaticResource SecondaryColor}" StrokeThickness="0.5"
                    Padding="20" BackgroundColor="#060f1e">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="18">

                    <HorizontalStackLayout Spacing="10">
                        <BoxView WidthRequest="3" HeightRequest="18" Color="{StaticResource SecondaryColor}" VerticalOptions="Center" />
                        <Label Text="FIRMWARE OVER-THE-AIR" FontFamily="RajdhaniBold" FontSize="15" TextColor="White" />
                    </HorizontalStackLayout>

                    <VerticalStackLayout Spacing="12">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="REPO URL" FontFamily="Rajdhani" FontSize="11" TextColor="{StaticResource SecondaryTextColor}" />
                            <Entry Text="{Binding OtaRepoUrl}"
                                   FontFamily="ShareTechMono" FontSize="12"
                                   BackgroundColor="#030810" TextColor="White" />
                        </VerticalStackLayout>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="VERSION" FontFamily="Rajdhani" FontSize="11" TextColor="{StaticResource SecondaryTextColor}" />
                                <Entry Text="{Binding OtaVersion}"
                                       FontFamily="ShareTechMono" FontSize="12"
                                       BackgroundColor="#030810" TextColor="White" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                <Label Text="FILENAME" FontFamily="Rajdhani" FontSize="11" TextColor="{StaticResource SecondaryTextColor}" />
                                <Entry Text="{Binding OtaFilename}"
                                       FontFamily="ShareTechMono" FontSize="12"
                                       BackgroundColor="#030810" TextColor="White" />
                            </VerticalStackLayout>
                        </Grid>

                        <VerticalStackLayout Spacing="4">
                            <Label Text="SHA-256 (64 hex)" FontFamily="Rajdhani" FontSize="11" TextColor="{StaticResource SecondaryTextColor}" />
                            <Entry Text="{Binding OtaSha}"
                                   FontFamily="ShareTechMono" FontSize="10"
                                   BackgroundColor="#030810" TextColor="White" />
                        </VerticalStackLayout>

                        <!-- URL final compus live -->
                        <Label Text="{Binding OtaFinalUrl}"
                               FontFamily="ShareTechMono" FontSize="10"
                               TextColor="{StaticResource PrimaryColor}"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>

                    <!-- Progress OTA activ -->
                    <VerticalStackLayout Spacing="6" IsVisible="{Binding OtaInProgress}">
                        <ProgressBar Progress="{Binding OtaProgress}"
                                     ProgressColor="{StaticResource PrimaryColor}"
                                     HeightRequest="6" />
                        <Label Text="{Binding OtaStatusMessage}"
                               FontFamily="ShareTechMono" FontSize="11"
                               TextColor="{Binding OtaStatusColor}"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>

                    <Button Text="TRIMITE UPDATE"
                            Command="{Binding SendOtaUpdateCommand}"
                            FontFamily="RajdhaniBold" FontSize="14"
                            BackgroundColor="{StaticResource SecondaryColor}"
                            TextColor="Black" />
                </VerticalStackLayout>
            </Border>

            <!-- ═══ SYSTEM ACTIONS ═══ -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                <Button Text="⏻ REBOOT"
                        Command="{Binding RebootCommand}"
                        FontFamily="RajdhaniBold" FontSize="14"
                        BorderColor="{StaticResource AccentColor}"
                        TextColor="{StaticResource AccentColor}" />
                <Button Grid.Column="1" Text="↺ REFRESH"
                        Command="{Binding RefreshCommand}"
                        FontFamily="RajdhaniBold" FontSize="14"
                        BorderColor="{StaticResource PrimaryColor}"
                        TextColor="{StaticResource PrimaryColor}" />
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
