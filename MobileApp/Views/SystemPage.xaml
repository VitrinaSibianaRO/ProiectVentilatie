<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProiectVentilatie.Mobile.Views.SystemPage"
             Title="Sistem">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            <Label Text="Sistem" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource PrimaryColor}"/>
            
            <Label Text="Optiuni si debug pentru placa ESP32 Carbon v3." />
            
            <Button Text="REBOOT ESP32" BackgroundColor="{StaticResource ErrorColor}" TextColor="White"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
