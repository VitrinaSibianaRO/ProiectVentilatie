<?xml version="1.0" encoding="utf-8" ?>
<mct:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mct="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="ProiectVentilatie.Mobile.Controls.IndustrialToast"
             Color="Transparent">

    <Border Stroke="{StaticResource PrimaryColor}" StrokeThickness="1" 
            BackgroundColor="#cc050a14" Padding="15,10"
            WidthRequest="300" HorizontalOptions="Center">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="10" />
        </Border.StrokeShape>
        <Grid ColumnDefinitions="Auto, *">
            <Label x:Name="IconLabel" Text="ℹ️" FontSize="18" VerticalOptions="Center" />
            <VerticalStackLayout Grid.Column="1" Margin="10,0,0,0">
                <Label x:Name="MessageLabel" Text="Message" 
                       FontFamily="RajdhaniBold" FontSize="14" 
                       TextColor="White" />
            </VerticalStackLayout>
        </Grid>
    </Border>
</mct:Popup>
