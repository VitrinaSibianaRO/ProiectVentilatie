<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:ProiectVentilatie.Mobile.Converters"
             x:Class="ProiectVentilatie.Mobile.Controls.FloatingNavBar"
             x:Name="self">
    
    <Border Margin="14,0,14,12"
            Padding="0,4"
            Stroke="#2E00e6ff"
            StrokeThickness="1"
            StrokeShape="RoundRectangle 20"
            HeightRequest="70"
            VerticalOptions="End">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FB00122c" Offset="0.0" />
                <GradientStop Color="#FB000a1c" Offset="1.0" />
            </LinearGradientBrush>
        </Border.Background>

        <Grid ColumnDefinitions="*,*,*,*,*">
            <!-- Dashboard -->
            <Grid Grid.Column="0" BackgroundColor="Transparent">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding NavigateCommand, Source={x:Reference self}}" CommandParameter="Dashboard" />
                </Grid.GestureRecognizers>
                <VerticalStackLayout Spacing="4" VerticalOptions="Center" InputTransparent="True">
                    <Image Source="dashboard_tab_icon.png" HeightRequest="24" WidthRequest="24" 
                           Opacity="{Binding IsDashboardActive, Source={x:Reference self}, Converter={StaticResource OpacityConverter}}" />
                    <Label Text="Dashboard" FontSize="10" HorizontalOptions="Center" Style="{StaticResource LabelRajdhani}" 
                           Opacity="{Binding IsDashboardActive, Source={x:Reference self}, Converter={StaticResource OpacityConverter}}" />
                </VerticalStackLayout>
            </Grid>

            <!-- Devices -->
            <Grid Grid.Column="1" BackgroundColor="Transparent">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding NavigateCommand, Source={x:Reference self}}" CommandParameter="Devices" />
                </Grid.GestureRecognizers>
                <VerticalStackLayout Spacing="4" VerticalOptions="Center" InputTransparent="True">
                    <Image Source="devices_tab_icon.png" HeightRequest="24" WidthRequest="24" 
                           Opacity="{Binding IsDevicesActive, Source={x:Reference self}, Converter={StaticResource OpacityConverter}}" />
                    <Label Text="Devices" FontSize="10" HorizontalOptions="Center" Style="{StaticResource LabelRajdhani}" 
                           Opacity="{Binding IsDevicesActive, Source={x:Reference self}, Converter={StaticResource OpacityConverter}}" />
                </VerticalStackLayout>
            </Grid>

            <!-- Settings -->
            <Grid Grid.Column="2" BackgroundColor="Transparent">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding NavigateCommand, Source={x:Reference self}}" CommandParameter="Settings" />
                </Grid.GestureRecognizers>
                <VerticalStackLayout Spacing="4" VerticalOptions="Center" InputTransparent="True">
                    <Image Source="settings_tab_icon.png" HeightRequest="24" WidthRequest="24" 
                           Opacity="{Binding IsSettingsActive, Source={x:Reference self}, Converter={StaticResource OpacityConverter}}" />
                    <Label Text="Settings" FontSize="10" HorizontalOptions="Center" Style="{StaticResource LabelRajdhani}" 
                           Opacity="{Binding IsSettingsActive, Source={x:Reference self}, Converter={StaticResource OpacityConverter}}" />
                </VerticalStackLayout>
            </Grid>

            <!-- Reports -->
            <Grid Grid.Column="3" BackgroundColor="Transparent">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding NavigateCommand, Source={x:Reference self}}" CommandParameter="Reports" />
                </Grid.GestureRecognizers>
                <VerticalStackLayout Spacing="4" VerticalOptions="Center" InputTransparent="True">
                    <Image Source="reports_tab_icon.png" HeightRequest="24" WidthRequest="24" 
                           Opacity="{Binding IsReportsActive, Source={x:Reference self}, Converter={StaticResource OpacityConverter}}" />
                    <Label Text="Reports" FontSize="10" HorizontalOptions="Center" Style="{StaticResource LabelRajdhani}" 
                           Opacity="{Binding IsReportsActive, Source={x:Reference self}, Converter={StaticResource OpacityConverter}}" />
                </VerticalStackLayout>
            </Grid>

            <!-- System -->
            <Grid Grid.Column="4" BackgroundColor="Transparent">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding NavigateCommand, Source={x:Reference self}}" CommandParameter="System" />
                </Grid.GestureRecognizers>
                <VerticalStackLayout Spacing="4" VerticalOptions="Center" InputTransparent="True">
                    <Image Source="system_tab_icon.png" HeightRequest="24" WidthRequest="24" 
                           Opacity="{Binding IsSystemActive, Source={x:Reference self}, Converter={StaticResource OpacityConverter}}" />
                    <Label Text="System" FontSize="10" HorizontalOptions="Center" Style="{StaticResource LabelRajdhani}" 
                           Opacity="{Binding IsSystemActive, Source={x:Reference self}, Converter={StaticResource OpacityConverter}}" />
                </VerticalStackLayout>
            </Grid>
        </Grid>
    </Border>
</ContentView>
