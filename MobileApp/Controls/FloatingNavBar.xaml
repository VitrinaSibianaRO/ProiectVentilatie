<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:ProiectVentilatie.Mobile.Converters"
             x:Class="ProiectVentilatie.Mobile.Controls.FloatingNavBar"
             x:Name="self">

    <ContentView.Resources>
        <converters:BoolToColorConverter x:Key="NavBoolToColor" />
    </ContentView.Resources>

    <!-- Container exterior cu margin si border rounded -->
    <Grid Margin="14,0,14,14" HeightRequest="68" VerticalOptions="End">

        <!-- Background gradient (vizual, NU primeste tap) -->
        <Border InputTransparent="True"
                Stroke="#2E00e6ff"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 22"
                Padding="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#FB00122c" Offset="0.0" />
                    <GradientStop Color="#FB000a1c" Offset="1.0" />
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!-- Tap layer: Grid cu 4 celule SOLIDE care primesc tap -->
        <Grid ColumnDefinitions="*,*,*,*" Padding="6,0">

            <!-- ===== DASHBOARD ===== -->
            <Grid Grid.Column="0" BackgroundColor="#02FFFFFF" RowDefinitions="3,Auto,Auto" RowSpacing="3" Padding="0,4">
                <BoxView Grid.Row="0" HeightRequest="3" WidthRequest="22"
                         Color="{StaticResource PrimaryCyan}" CornerRadius="0,0,2,2"
                         HorizontalOptions="Center" InputTransparent="True"
                         IsVisible="{Binding IsDashboardActive, Source={x:Reference self}}" />
                <Path Grid.Row="1"
                      Data="M3,3 H10 V10 H3 Z M14,3 H21 V10 H14 Z M3,14 H10 V21 H3 Z M14,14 H21 V21 H14 Z"
                      Fill="Transparent" StrokeThickness="2" InputTransparent="True"
                      HeightRequest="22" WidthRequest="22" HorizontalOptions="Center" Aspect="Uniform"
                      Stroke="{Binding IsDashboardActive, Source={x:Reference self}, Converter={StaticResource NavBoolToColor}, ConverterParameter=cyan}" />
                <Label Grid.Row="2" Text="Dashboard" FontSize="10" HorizontalOptions="Center" InputTransparent="True"
                       Style="{StaticResource LabelRajdhani}"
                       TextColor="{Binding IsDashboardActive, Source={x:Reference self}, Converter={StaticResource NavBoolToColor}, ConverterParameter=cyan}" />
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnTapDashboard" />
                </Grid.GestureRecognizers>
            </Grid>

            <!-- ===== DEVICES ===== -->
            <Grid Grid.Column="1" BackgroundColor="#02FFFFFF" RowDefinitions="3,Auto,Auto" RowSpacing="3" Padding="0,4">
                <BoxView Grid.Row="0" HeightRequest="3" WidthRequest="22"
                         Color="{StaticResource PrimaryCyan}" CornerRadius="0,0,2,2"
                         HorizontalOptions="Center" InputTransparent="True"
                         IsVisible="{Binding IsDevicesActive, Source={x:Reference self}}" />
                <Path Grid.Row="1"
                      Data="M2,4 H22 V16 H2 Z M8,16 L6,20 H18 L16,16 M10,20 V22 H14"
                      Fill="Transparent" StrokeThickness="2" InputTransparent="True"
                      HeightRequest="22" WidthRequest="22" HorizontalOptions="Center" Aspect="Uniform"
                      Stroke="{Binding IsDevicesActive, Source={x:Reference self}, Converter={StaticResource NavBoolToColor}, ConverterParameter=cyan}" />
                <Label Grid.Row="2" Text="Devices" FontSize="10" HorizontalOptions="Center" InputTransparent="True"
                       Style="{StaticResource LabelRajdhani}"
                       TextColor="{Binding IsDevicesActive, Source={x:Reference self}, Converter={StaticResource NavBoolToColor}, ConverterParameter=cyan}" />
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnTapDevices" />
                </Grid.GestureRecognizers>
            </Grid>

            <!-- ===== SETTINGS ===== -->
            <Grid Grid.Column="2" BackgroundColor="#02FFFFFF" RowDefinitions="3,Auto,Auto" RowSpacing="3" Padding="0,4">
                <BoxView Grid.Row="0" HeightRequest="3" WidthRequest="22"
                         Color="{StaticResource PrimaryCyan}" CornerRadius="0,0,2,2"
                         HorizontalOptions="Center" InputTransparent="True"
                         IsVisible="{Binding IsSettingsActive, Source={x:Reference self}}" />
                <Path Grid.Row="1"
                      Data="M12,8 A4,4 0 1,1 12,16 A4,4 0 1,1 12,8 M12,2 V5 M12,19 V22 M2,12 H5 M19,12 H22 M4.9,4.9 L7,7 M17,17 L19.1,19.1 M4.9,19.1 L7,17 M17,7 L19.1,4.9"
                      Fill="Transparent" StrokeThickness="2" InputTransparent="True"
                      HeightRequest="22" WidthRequest="22" HorizontalOptions="Center" Aspect="Uniform"
                      Stroke="{Binding IsSettingsActive, Source={x:Reference self}, Converter={StaticResource NavBoolToColor}, ConverterParameter=cyan}" />
                <Label Grid.Row="2" Text="Settings" FontSize="10" HorizontalOptions="Center" InputTransparent="True"
                       Style="{StaticResource LabelRajdhani}"
                       TextColor="{Binding IsSettingsActive, Source={x:Reference self}, Converter={StaticResource NavBoolToColor}, ConverterParameter=cyan}" />
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnTapSettings" />
                </Grid.GestureRecognizers>
            </Grid>

            <!-- ===== SYSTEM ===== -->
            <Grid Grid.Column="3" BackgroundColor="#02FFFFFF" RowDefinitions="3,Auto,Auto" RowSpacing="3" Padding="0,4">
                <BoxView Grid.Row="0" HeightRequest="3" WidthRequest="22"
                         Color="{StaticResource PrimaryCyan}" CornerRadius="0,0,2,2"
                         HorizontalOptions="Center" InputTransparent="True"
                         IsVisible="{Binding IsSystemActive, Source={x:Reference self}}" />
                <Path Grid.Row="1"
                      Data="M4,4 H10 L12,7 H20 V20 H4 Z M4,11 H20 M4,15 H20"
                      Fill="Transparent" StrokeThickness="2" InputTransparent="True"
                      HeightRequest="22" WidthRequest="22" HorizontalOptions="Center" Aspect="Uniform"
                      Stroke="{Binding IsSystemActive, Source={x:Reference self}, Converter={StaticResource NavBoolToColor}, ConverterParameter=cyan}" />
                <Label Grid.Row="2" Text="System" FontSize="10" HorizontalOptions="Center" InputTransparent="True"
                       Style="{StaticResource LabelRajdhani}"
                       TextColor="{Binding IsSystemActive, Source={x:Reference self}, Converter={StaticResource NavBoolToColor}, ConverterParameter=cyan}" />
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnTapSystem" />
                </Grid.GestureRecognizers>
            </Grid>
        </Grid>
    </Grid>
</ContentView>
