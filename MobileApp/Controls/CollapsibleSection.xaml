<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProiectVentilatie.Mobile.Controls.CollapsibleSection"
             x:Name="self">

    <Border Style="{StaticResource IndustrialCard}">
        <VerticalStackLayout Spacing="0">

            <!-- Header row — TapGestureRecognizer (reliable on Android, unlike transparent Button) -->
            <Grid ColumnDefinitions="*,Auto" Padding="0,4">
                <Label Grid.Column="0"
                       Text="{Binding Title, Source={x:Reference self}}"
                       TextColor="White"
                       FontSize="16"
                       FontAttributes="Bold"
                       FontFamily="Rajdhani"
                       VerticalOptions="Center" />
                <Label Grid.Column="1"
                       Text="{Binding ChevronText, Source={x:Reference self}}"
                       VerticalOptions="Center"
                       FontSize="18"
                       Opacity="0.55"
                       TextColor="White" />
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding ToggleCommand, Source={x:Reference self}}" />
                </Grid.GestureRecognizers>
            </Grid>

            <!-- Collapsible content -->
            <ContentView Content="{Binding InnerContent, Source={x:Reference self}}"
                         IsVisible="{Binding IsExpanded, Source={x:Reference self}}"
                         Margin="0,12,0,0" />

        </VerticalStackLayout>
    </Border>

</ContentView>
