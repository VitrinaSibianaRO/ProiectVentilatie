<?xml version="1.0" encoding="utf-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:ProiectVentilatie.Mobile"
             x:Class="ProiectVentilatie.Mobile.App">
    <Application.Resources>
        <ResourceDictionary>
            <!-- Dark Mode + Turquoise Theme -->
            <!-- Industrial Cyberpunk Theme -->
            <Color x:Key="BackgroundColor">#050a14</Color>
            <Color x:Key="SurfaceColor">#0d1e2e</Color>
            <Color x:Key="PrimaryColor">#00e6ff</Color> <!-- Neon Cyan -->
            <Color x:Key="SecondaryColor">#00e87a</Color> <!-- Emerald Green -->
            <Color x:Key="AccentColor">#ff7a45</Color> <!-- Industrial Orange -->
            <Color x:Key="TextColor">#FFFFFF</Color>
            <Color x:Key="SecondaryTextColor">#6688aa</Color>
            <Color x:Key="ErrorColor">#ff4422</Color>

            <Style TargetType="Page">
                <Setter Property="BackgroundColor" Value="{StaticResource BackgroundColor}" />
            </Style>

            <Style TargetType="Label">
                <Setter Property="TextColor" Value="{StaticResource TextColor}" />
                <Setter Property="FontFamily" Value="Rajdhani" />
            </Style>
            
            <Style TargetType="Button">
                <Setter Property="BackgroundColor" Value="Transparent" />
                <Setter Property="TextColor" Value="{StaticResource PrimaryColor}" />
                <Setter Property="BorderColor" Value="{StaticResource PrimaryColor}" />
                <Setter Property="BorderWidth" Value="1.5" />
                <Setter Property="FontFamily" Value="Rajdhani" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="HeightRequest" Value="44" />
            </Style>
            
            <Style TargetType="Frame">
                <Setter Property="BackgroundColor" Value="{StaticResource SurfaceColor}" />
                <Setter Property="BorderColor" Value="{StaticResource PrimaryColor}" />
                <Setter Property="CornerRadius" Value="14" />
                <Setter Property="HasShadow" Value="False" />
                <Setter Property="Padding" Value="15" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
